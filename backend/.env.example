# Copy this file to .env and fill in real values. Never commit the real .env.

DATABASE_URL=postgresql://user:password@localhost:5432/washly
SECRET_KEY=change-me-to-a-long-random-value-before-any-real-deployment
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of frontend origins allowed to call this API.
# In production this must NOT be "*" — list the real domain(s).
CORS_ORIGINS=http://localhost:3000

# Path to the Firebase Admin SDK service account JSON (download from
# Firebase console > Project settings > Service accounts). Never commit it.
FIREBASE_SERVICE_ACCOUNT_FILE=firebase-service-account.json
